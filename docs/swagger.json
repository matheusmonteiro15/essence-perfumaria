{
  "openapi": "3.0.0",
  "info": {
    "title": "Essence API - Alta Perfumaria",
    "description": "Documentação Oficial AV3 (Swagger UI)",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Servidor Local de Desenvolvimento"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Cadastra um novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "João da Silva" },
                  "email": { "type": "string", "example": "joao.essence@gmail.com" },
                  "cpf": { "type": "string", "example": "12345678912" },
                  "senha": { "type": "string", "example": "senhaforte123" },
                  "data_nascimento": { "type": "string", "format": "date", "example": "1994-10-25" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário cadastrado com sucesso!" },
          "400": { "description": "Validação de dados falhou." }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Realiza login e devolve o Token JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@essence.com" },
                  "senha": { "type": "string", "example": "senha1234" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login bem sucedido com Token JWT retornado." },
          "401": { "description": "Credenciais inválidas." }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["Catálogo"],
        "summary": "Lista todos os perfumes com suas notas olfativas",
        "responses": {
          "200": { "description": "Lista de produtos retornada." }
        }
      },
      "post": {
        "tags": ["Catálogo"],
        "summary": "Cadastra um novo perfume (Requer Transação)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": { "type": "string", "example": "Versace Eros" },
                  "marca_id": { "type": "integer", "example": 8 },
                  "categoria_id": { "type": "integer", "example": 3 },
                  "familia_olfativa_id": { "type": "integer", "example": 7 },
                  "preco": { "type": "number", "example": 650.00 },
                  "estoque_qtd": { "type": "integer", "example": 20 },
                  "descricao": { "type": "string", "example": "O amor, a paixão." },
                  "ingredientes": { "type": "string", "example": "Menta, Limão" },
                  "ocasiao_ideal": { "type": "string", "example": "Baladas" },
                  "topo": { "type": "string", "example": "Hortelã, Limão" },
                  "coracao": { "type": "string", "example": "Ambroxan" },
                  "base": { "type": "string", "example": "Baunilha" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Perfume criado." }
        }
      }
    },
    "/api/cart": {
      "get": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Lista o carrinho de compras do usuário",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Carrinho retornado com o total matemático." }
        }
      }
    },
    "/api/cart/add": {
      "post": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Adiciona um perfume ao carrinho e trava o estoque",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "produto_id": { "type": "integer", "example": 1 },
                  "quantidade": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item adicionado." },
          "400": { "description": "Quantidade excede o estoque." }
        }
      }
    },
    "/api/cart/remove/{id}": {
      "delete": {
        "tags": ["Carrinho (Protegido)"],
        "summary": "Remove um item do carrinho",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Removido com sucesso." }
        }
      }
    }
  }
}
